# Database
DATABASE_URL=postgres://numduel:numduel@localhost:5432/numduel?sslmode=disable
BACKUP_DATABASE_URL=postgres://numduel:numduel@localhost:5433/numduel_backup?sslmode=disable
# Docker Compose の backend では migrate サービス後に SKIP_MIGRATE=1 を設定
# DB_MAX_IDLE_CONNS=20
# DB_MAX_OPEN_CONNS=80
# DB_CONN_MAX_LIFETIME=30m
# DB_CONN_MAX_IDLE_TIME=5m

# Redis (optional locally; required for JWT revoke / locks / turns / WS session)
REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Server
PORT=8080

# Auth
JWT_SECRET=change-me-to-a-secret-key-at-least-32-chars
JWT_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=7
COOKIE_SECURE=false

# Game
GAME_SECRET_PEPPER=change-me-to-a-pepper-at-least-32-bytes-long!!
GAME_LOCK_SECONDS=2
TURN_DURATION_SECONDS=30
TURN_TIMEOUT_POLL_SECONDS=1
SECRET_SETUP_SECONDS=60
SECRET_TIMEOUT_POLL_SECONDS=1
SESSION_TIMEOUT_MINUTES=5
AUTO_LOGOUT_POLL_SECONDS=60

# Master seed (created once when no master exists)
NUMDUEL_MASTER_EMAIL=admin@local.test
NUMDUEL_MASTER_PASSWORD=ChangeMeOnFirstLogin!

# WebSocket / CORS (comma-separated origins; empty CORS = no CORS headers)
CORS_ALLOWED_ORIGINS=http://localhost:5173
WS_ALLOWED_ORIGINS=
