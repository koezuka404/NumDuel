# Database
DATABASE_URL=postgres://numduel:numduel@localhost:5432/numduel?sslmode=disable
BACKUP_DATABASE_URL=postgres://numduel:numduel@localhost:5433/numduel_backup?sslmode=disable
# Docker Compose の backend では migrate サービス後に SKIP_MIGRATE=1 を設定
# DB_MAX_IDLE_CONNS=20
# DB_MAX_OPEN_CONNS=80
# DB_CONN_MAX_LIFETIME=30m
# DB_CONN_MAX_IDLE_TIME=5m

# Server
PORT=8080

# Auth
JWT_SECRET=change-me-to-a-secret-key-at-least-32-chars
JWT_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=7
COOKIE_SECURE=false

# Game
GAME_SECRET_PEPPER=change-me-to-a-pepper-at-least-32-bytes-long!!
GAME_LOCK_SECONDS=2
TURN_DURATION_SECONDS=30

# WebSocket (comma-separated origins; empty = allow all in dev)
WS_ALLOWED_ORIGINS=
